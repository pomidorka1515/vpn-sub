{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "VPN Config",
    "type": "object",
    "required": [
        "uri", "api_token", "panel_alert_cooldown", "salt", "fingerprints", "nodes", "bot", "routing",
        "json_template",
        "publicbot", "codes", "3xui", "sub_name", "description", "flags",
        "users", "tokens", "displaynames", "tgids",
        "bw", "wl_bw", "profiles", "json_profiles", "profileDescriptions", "whitelistProfiles",
        "masterLinks", "profileNodes", "userFingerprints",
        "time", "status", "statusTime", "statusWl",
        "_notified", "_wl_notified"
    ],
    "additionalProperties": false,
    "properties": {
        "$schema": { "type": "string", "description": "Schema file." },
        "uri": { "type": "string", "description": "Main URI for the service.", "default": "sub" },
        "api_uri": { "type": "string", "description": "Admin API URI." },
        "api_token": { "type": "string", "description": "Admin API Access token." },
        "panel_alert_cooldown": { "type": "integer", "description": "Panel alert cooldown in seconds.", "default": 3600 },
        "domain": { "type": "string", "description": "Your domain." },
        "salt": { "type": "string", "description": "Salt for passwords, pick something strong." },
        "sub_name": { "type": "string", "description": "Text displayed in VPN clients." },

        "fingerprints": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true,
            "default": ["safari", "chrome", "edge", "firefox"],
            "description": "List of allowed fingerprints. Dont add anything invalid, see xray uTLS section for the full list."
        },

        "nodes": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "List of nodes. Must be raw domains or IPs."
        },

        "bot": {
            "type": "object",
            "required": ["token", "whitelist"],
            "additionalProperties": false,
            "description": "Admin bot configuration object.",
            "properties": {
                "token": { "type": "string", "description": "Token for your admin bot." },
                "whitelist": {
                    "type": "array",
                    "description": "List of users who are allowed to use the admin bot (UIDs)",
                    "default": [],
                    "items": { "type": "integer" }
                }
            }
        },

        "routing": {
            "type": "object",
            "description": "Happ routing object. Leave blank to disable.",
            "default": {},
            "required": ["Name", "GlobalProxy", "DomainStrategy", "DirectSites", "DirectPackages", "DirectIp"],
            "properties": {
                "Name": { "type": "string" },
                "GlobalProxy": { "type": "boolean" },
                "DomainStrategy": { "type": "string" },
                "DirectSites": { "type": "array", "items": { "type": "string" } },
                "DirectPackages": { "type": "array", "items": { "type": "string" } },
                "DirectIp": { "type": "array", "items": { "type": "string" } }
            }
        },

        "json_template": {
            "type": "object",
            "description": "JSON Profile template.",
            "default": {},
            "required": ["dns", "routing", "inbounds", "outbounds", "remarks"],
            "properties": {
                "servers": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["servers", "queryStrategy"],
                    "properties": {
                        "servers": { "type": "array" },
                        "queryStrategy": { "type": "string" }
                    }
                },
                "routing": {
                    "type": "object",
                    "additionalProperties": true,
                    "required": ["rules", "domainStrategy"],
                    "$comment": "im not writing a full schema"
                }
            },
            "additionalProperties": true
        },
        "webui_passwords": {
            "type": "object",
            "description": "WebUI hashed passwords.",
            "additionalProperties": { "type": "string" }
        },
        "webui_users": {
            "type": "object",
            "description": "WebUI references \"external_username\": \"internal_username\"",
            "additionalProperties": { "type": "string" }
        },

        "funny_strings": {
            "type": "array",
            "description": "type shit",
            "items": { "type": "string" }
        },

        "publicbot": {
            "type": "object",
            "description": "Object for the public bot.",
            "required": ["token", "tg_lang", "lang"],
            "additionalProperties": false,
            "properties": {
                "token": { "type": "string" },
                "tg_lang": {
                    "type": "object",
                    "additionalProperties": { "type": "string", "enum": ["ru", "en"] }
                },
                "lang": {
                    "type": "object",
                    "required": ["ru", "en"],
                    "additionalProperties": false,
                    "properties": {
                        "ru": { "$ref": "#/$defs/langStrings" },
                        "en": { "$ref": "#/$defs/langStrings" }
                    }
                }
            }
        },

        "codes": {
            "type": "array",
            "description": "Object of codes.",
            "items": {
                "type": "object",
                "required": ["code", "action", "perma", "days", "gb"],
                "additionalProperties": false,
                "properties": {
                    "code": { "type": "string" },
                    "action": { "type": "string", "enum": ["register", "bonus"] },
                    "perma": { "type": "boolean" },
                    "days": { "type": "integer", "minimum": 0 },
                    "gb": { "type": "integer", "minimum": 0 },
                    "wl_gb": { "type": "integer", "minimum": 0 }
                }
            }
        },

        "3xui": {
            "type": "object",
            "description": "3x-ui panels.",
            "additionalProperties": {
                "type": "object",
                "required": ["name", "address", "port", "uri", "username", "password", "https", "whitelist", "ignore_inbounds"],
                "additionalProperties": false,
                "properties": {
                    "name": { "type": "string" },
                    "address": { "type": "string" },
                    "port": { "type": ["string", "integer"] },
                    "uri": { "type": "string" },
                    "username": { "type": "string" },
                    "password": { "type": "string" },
                    "https": { "type": "boolean" },
                    "whitelist": { "type": "boolean" },
                    "nginx_auth": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 2,
                        "maxItems": 2
                    },
                    "ignore_inbounds": {
                        "type": "array",
                        "items": { "type": "integer" }
                    },
                    "inject_headers": { "type": "object" }
                }
            }
        },

        "description": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 14,
            "maxItems": 14
        },

        "flags": {
            "type": "object",
            "additionalProperties": { "type": "string" }
        },

        "users": {
            "type": "object",
            "additionalProperties": {
                "type": "string",
                "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
            }
        },

        "tokens": {
            "type": "object",
            "additionalProperties": { "type": "string" }
        },

        "displaynames": {
            "type": "object",
            "additionalProperties": { "type": "string" }
        },

        "tgids": {
            "type": "object",
            "additionalProperties": { "type": "string" }
        },

        "bw": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/bwEntry" }
        },

        "wl_bw": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/bwEntry" }
        },

        "profiles": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/bilingualPair" }
        },
        
        "json_profiles": { "type": "object" },

        "profileDescriptions": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/bilingualPair" }
        },

        "whitelistProfiles": {
            "type": "array",
            "items": { "type": "string" }
        },

        "xhttpExtra": {
            "type": "object",
            "additionalProperties": { "type": "object" }
        },

        "masterLinks": {
            "type": "object",
            "additionalProperties": { "type": "string" }
        },

        "profileNodes": {
            "type": "object",
            "additionalProperties": { "type": "string" }
        },

        "userFingerprints": {
            "type": "object",
            "additionalProperties": { "type": "string" }
        },

        "time": {
            "type": "object",
            "additionalProperties": { "type": "integer", "minimum": 0 }
        },

        "status": {
            "type": "object",
            "additionalProperties": { "type": "boolean" }
        },

        "statusTime": {
            "type": "object",
            "additionalProperties": { "type": "boolean" }
        },

        "statusWl": {
            "type": "object",
            "additionalProperties": { "type": "boolean" }
        },

        "_notified": {
            "type": "array",
            "items": { "type": ["integer", "null"] }
        },

        "_wl_notified": {
            "type": "array",
            "items": { "type": ["integer", "null"] }
        },

        "_last_reset": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
    },

    "$defs": {
        "bwEntry": {
            "type": "array",
            "prefixItems": [
                { "type": "integer", "minimum": 0, "description": "limit in GB, 0 = unlimited" },
                { "type": "integer", "minimum": 0, "description": "used bytes this month" }
            ],
            "items": false,
            "minItems": 2,
            "maxItems": 2
        },
        "bilingualPair": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
        },
        "langStrings": {
            "type": "object",
            "additionalProperties": { "type": "string" }
        }
    }
}
